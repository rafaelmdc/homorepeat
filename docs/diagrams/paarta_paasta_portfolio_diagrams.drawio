          <mxGeometry x="1090" y="170" width="500" height="540" as="geometry"/>
        </mxCell>
        <mxCell id="pb-w1" value="celery-import-worker · imports queue · concurrency 2&#xa;run_import_batch — validate + persist run, trigger post-import warmup fan-out" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#A9CFE4;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;" vertex="1" parent="pb-workers">
          <mxGeometry x="20" y="50" width="460" height="62" as="geometry"/>
        </mxCell>
        <mxCell id="pb-w2" value="celery-upload-worker · uploads queue · concurrency 2&#xa;extract_uploaded_run — unzip, validate contract, mark READY" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#A9CFE4;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;" vertex="1" parent="pb-workers">
          <mxGeometry x="20" y="122" width="460" height="62" as="geometry"/>
        </mxCell>
        <mxCell id="pb-w3" value="celery-graph-worker · payload_graph · autoscale 1–4&#xa;warm_stats_bundle — build stats payload, write result to Redis DB 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#A9CFE4;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;" vertex="1" parent="pb-workers">
          <mxGeometry x="20" y="194" width="460" height="62" as="geometry"/>
        </mxCell>
        <mxCell id="pb-w4" value="celery-download-worker · downloads queue · concurrency 2&#xa;build TSV / FASTA artifacts on disk, expire stale download builds" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#A9CFE4;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;" vertex="1" parent="pb-workers">
          <mxGeometry x="20" y="266" width="460" height="62" as="geometry"/>
        </mxCell>
        <mxCell id="pb-w5" value="celery-deletion-worker · deletions queue · concurrency 1 (sequential)&#xa;delete_pipeline_run_job — cascade-delete run rows, bump CatalogVersion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#A9CFE4;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;" vertex="1" parent="pb-workers">
          <mxGeometry x="20" y="338" width="460" height="62" as="geometry"/>
        </mxCell>
        <mxCell id="pb-beat" value="celery-beat · Scheduler&#xa;reset_stale_import_batches (5 min) · cleanup_stale_uploaded_runs (1 h) · expire_stale_download_builds (6 h)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF3F6;strokeColor=#9DB0B9;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;" vertex="1" parent="pb-workers">
