          <mxGeometry x="0" y="0" width="1800" height="1000" as="geometry"/>
        </mxCell>
        <mxCell id="pb-title" value="PAARTA browser system" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=34;fontStyle=1;fontColor=#142027;fontFamily=Raleway;" vertex="1" parent="1">
          <mxGeometry x="70" y="56" width="760" height="48" as="geometry"/>
        </mxCell>
        <mxCell id="pb-subtitle" value="Django serves the browser; five specialised Celery workers consume Redis-queued tasks and persist results to PostgreSQL." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=16;fontColor=#4C6470;fontFamily=Roboto;" vertex="1" parent="1">
          <mxGeometry x="72" y="106" width="1200" height="32" as="geometry"/>
        </mxCell>
        <mxCell id="pb-line" value="" style="shape=line;html=1;strokeColor=#1387C1;strokeWidth=4;" vertex="1" parent="1">
          <mxGeometry x="72" y="148" width="190" height="10" as="geometry"/>
        </mxCell>

        <!-- Browser / Client -->
        <mxCell id="pb-browser" value="Browser / Client" style="swimlane;whiteSpace=wrap;html=1;startSize=38;rounded=1;arcSize=6;fillColor=#EEF3F6;strokeColor=#B9C8D0;fontColor=#142027;fontSize=15;fontStyle=1;fontFamily=Poppins;" vertex="1" parent="1">
          <mxGeometry x="55" y="170" width="205" height="540" as="geometry"/>
        </mxCell>
        <mxCell id="pb-b1" value="Chunked upload&#xa;fetch() — start / chunk / complete&#xa;SHA-256 per chunk" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B9C8D0;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;" vertex="1" parent="pb-browser">
          <mxGeometry x="15" y="52" width="175" height="72" as="geometry"/>
        </mxCell>
        <mxCell id="pb-b2" value="Import polling&#xa;page reload every 5 s&#xa;while PENDING / RUNNING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B9C8D0;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;" vertex="1" parent="pb-browser">
          <mxGeometry x="15" y="144" width="175" height="72" as="geometry"/>
        </mxCell>
        <mxCell id="pb-b3" value="Async status checks&#xa;/payload-builds/{id}/status/&#xa;/download-builds/{id}/status/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B9C8D0;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;" vertex="1" parent="pb-browser">
          <mxGeometry x="15" y="236" width="175" height="72" as="geometry"/>
        </mxCell>
        <mxCell id="pb-b4" value="Browse + export&#xa;repeat calls, genomes,&#xa;proteins, taxa, TSV / FASTA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B9C8D0;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;" vertex="1" parent="pb-browser">
          <mxGeometry x="15" y="328" width="175" height="72" as="geometry"/>
        </mxCell>

        <!-- Django / Gunicorn -->
        <mxCell id="pb-django" value="Django · Gunicorn (4 workers)" style="swimlane;whiteSpace=wrap;html=1;startSize=38;rounded=1;arcSize=6;fillColor=#EAF8F1;strokeColor=#7ECDA5;fontColor=#142027;fontSize=15;fontStyle=1;fontFamily=Poppins;" vertex="1" parent="1">
          <mxGeometry x="315" y="170" width="380" height="540" as="geometry"/>
        </mxCell>
        <mxCell id="pb-d1" value="Import views&#xa;upload: start, chunk, complete, retry&#xa;import batch enqueue, run delete" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9FD8BA;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;" vertex="1" parent="pb-django">
          <mxGeometry x="20" y="50" width="340" height="72" as="geometry"/>
        </mxCell>
        <mxCell id="pb-d2" value="Browser views&#xa;repeat browser, stats bundles, canonical catalog&#xa;payload + download build status endpoints" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9FD8BA;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;" vertex="1" parent="pb-django">
          <mxGeometry x="20" y="138" width="340" height="72" as="geometry"/>
        </mxCell>
