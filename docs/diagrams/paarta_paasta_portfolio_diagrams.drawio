          <mxGeometry x="135" y="260" width="210" height="66" as="geometry"/>
        </mxCell>
        <mxCell id="rc-decision" value="exact AA match?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E1B56F;fontColor=#142027;fontSize=14;fontFamily=Roboto;spacing=8;" vertex="1" parent="rc-validation-container">
          <mxGeometry x="140" y="365" width="200" height="86" as="geometry"/>
        </mxCell>
        <mxCell id="rc-pass" value="PASS&#xa;codon sequence + codon usage rows" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF8F1;strokeColor=#7ECDA5;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;" vertex="1" parent="rc-validation-container">
          <mxGeometry x="40" y="470" width="180" height="62" as="geometry"/>
        </mxCell>
        <mxCell id="rc-fail" value="FAIL&#xa;retain AA call, record warning, exclude from codon shares" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEDEE;strokeColor=#DFA0A7;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;" vertex="1" parent="rc-validation-container">
          <mxGeometry x="260" y="465" width="185" height="72" as="geometry"/>
        </mxCell>
        <mxCell id="rc-a1" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#4C6470;" edge="1" parent="rc-validation-container" source="rc-call" target="rc-cds"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rc-a2" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#4C6470;" edge="1" parent="rc-validation-container" source="rc-cds" target="rc-translate"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rc-a3" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#4C6470;" edge="1" parent="rc-validation-container" source="rc-translate" target="rc-decision"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rc-a4" value="yes" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#279A63;fontColor=#279A63;fontStyle=1;" edge="1" parent="rc-validation-container" source="rc-decision" target="rc-pass"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rc-a5" value="no" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#C95A64;fontColor=#C95A64;fontStyle=1;" edge="1" parent="rc-validation-container" source="rc-decision" target="rc-fail"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="paarta-browser-system" name="PAARTA browser system">
    <mxGraphModel dx="1420" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
