          <mxGeometry x="20" y="226" width="340" height="72" as="geometry"/>
        </mxCell>
        <mxCell id="pb-d4" value="Cache layer · django-redis DB 1&#xa;stats bundle reads, query cache" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF5E6;strokeColor=#E6C78F;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;" vertex="1" parent="pb-django">
          <mxGeometry x="20" y="314" width="340" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="pb-d5" value="ORM · Django models → PostgreSQL&#xa;ImportBatch, UploadedRun, PipelineRun,&#xa;Genome, Protein, RepeatCall, PayloadBuild…" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4F1EA;strokeColor=#D2B883;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;" vertex="1" parent="pb-django">
          <mxGeometry x="20" y="390" width="340" height="72" as="geometry"/>
        </mxCell>

        <!-- Redis -->
        <mxCell id="pb-redis" value="Redis 7" style="swimlane;whiteSpace=wrap;html=1;startSize=38;rounded=1;arcSize=6;fillColor=#FFF5E6;strokeColor=#E1B56F;fontColor=#142027;fontSize=15;fontStyle=1;fontFamily=Poppins;" vertex="1" parent="1">
          <mxGeometry x="750" y="170" width="285" height="540" as="geometry"/>
        </mxCell>
        <mxCell id="pb-r0" value="DB 0 · Celery Broker&#xa;&#xa;Queue → Worker&#xa;imports → import-worker&#xa;uploads → upload-worker&#xa;payload_graph → graph-worker&#xa;downloads → download-worker&#xa;deletions → deletion-worker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E6C78F;fontColor=#142027;fontSize=13;fontFamily=Roboto;arcSize=8;spacing=8;align=left;spacingLeft=12;" vertex="1" parent="pb-redis">
