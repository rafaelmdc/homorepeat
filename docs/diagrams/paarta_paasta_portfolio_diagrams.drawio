          <mxGeometry x="70" y="50" width="700" height="32" as="geometry"/>
        </mxCell>
        <mxCell id="pb-subtitle" value="A standard web application separates synchronous browsing from asynchronous, long-running tasks dispatched through a message broker." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=13;fontColor=#555555;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="70" y="84" width="1200" height="24" as="geometry"/>
        </mxCell>

