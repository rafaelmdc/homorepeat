# Copy to `.env` for local Docker Compose defaults.
# Docker Compose reads `.env` automatically from the repo root.
# For shell commands like `python3 manage.py ...`, either export these vars
# yourself or source the file first.

# Django app
DJANGO_SECRET_KEY=dev-secret-key
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_TIME_ZONE=UTC

# Postgres / Django DB connection
POSTGRES_DB=homorepeat
POSTGRES_USER=homorepeat
POSTGRES_PASSWORD=homorepeat
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=homorepeat
DATABASE_USER=homorepeat
DATABASE_PASSWORD=homorepeat
DATABASE_HOST=postgres
DATABASE_PORT=5432

# Optional: directory containing pipeline run folders so the imports UI can
# auto-detect published runs. Leave empty to disable auto-discovery.
HOMOREPEAT_RUNS_ROOT=
