# Copy to `.env` for local Docker Compose defaults.
# Docker Compose reads `.env` automatically from the repo root.
# For shell commands like `python3 manage.py ...`, either export these vars
# yourself or source the file first.

# Django app
DJANGO_SECRET_KEY=dev-secret-key
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_TIME_ZONE=UTC
# Local trusted-only mode: set to true to bypass Django staff/admin login.
no_admin=0

# Postgres / Django DB connection
POSTGRES_DB=homorepeat
POSTGRES_USER=homorepeat
POSTGRES_PASSWORD=homorepeat
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_HOST=postgres
DATABASE_PORT=5432

# Optional: host-side directory containing pipeline run folders. Docker Compose
# mounts this read-only at /workspace/homorepeat_pipeline/runs for the app.
HOMOREPEAT_RUNS_ROOT=

# GUI upload/import storage inside Docker. Usually leave these unchanged.
HOMOREPEAT_IMPORTS_ROOT=/data/imports
HOMOREPEAT_UPLOAD_MAX_ZIP_BYTES=5368709120
HOMOREPEAT_UPLOAD_CHUNK_BYTES=8388608
HOMOREPEAT_UPLOAD_MAX_EXTRACTED_BYTES=53687091200
HOMOREPEAT_UPLOAD_MAX_FILES=200000
